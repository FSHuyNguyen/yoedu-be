generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
  DELETED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id            String    @id @default(uuid())

  email         String    @unique
  password      String

  fullName      String?
  phone         String?
  address       String?

  avatarUrl     String?

  dateOfBirth   DateTime?
  gender        Gender?

  lastLoginAt   DateTime?

  role          Role      @default(STUDENT)
  status        Status    @default(ACTIVE)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student       Student?
  teacher       Teacher?

  @@map("users")
}

model Student {
  id                    String    @id @default(uuid())

  userId                String    @unique

  // mã học viên nội bộ
  studentCode           String @unique

  // thông tin phụ huynh
  parentName            String?
  parentPhone           String?

  // trường / lớp hiện tại
  schoolName            String?
  grade                 String?

  // trình độ đầu vào
  entryAcademicLevel    String?

  // điểm gần nhất
  latestTestScore       Float?

  // mục tiêu học
  learningGoal          String?

  // ghi chú nội bộ
  note                  String?

  // ngày tham gia
  joinedAt              DateTime? @default(now())

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("students")
}

model Teacher {
  id                    String    @id @default(uuid())

  userId                String    @unique

  // mã giáo viên nội bộ
  teacherCode           String    @unique

  // giới thiệu
  bio                   String?

  // chuyên môn
  specialization        String?

  // bằng cấp
  qualification         String?

  // số năm kinh nghiệm
  yearsOfExperience     Int?

  // trạng thái nhận lớp
  isAvailable           Boolean   @default(true)

  // ngày vào làm
  joinedAt              DateTime? @default(now())

  // ghi chú nội bộ
  note                  String?

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("teachers")
}