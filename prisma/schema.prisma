generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================== ENUM ==================================
enum Role {
  ADMIN
  STAFF
  TEACHER
  STUDENT
  PARENT
}

enum Status {
  ACTIVE
  INACTIVE
  DELETED
}

enum StudentStatus {
  ACTIVE // Đang tham gia học
  PAUSED // Đang tạm ngưng học
  DROPPED // Đã rời khỏi chương trình học, không còn tham gia lớp hiện tại
}

enum TeacherStatus {
  ACTIVE // đang dạy bình thường
  PAUSED // tạm nghỉ (có thể quay lại)
  INACTIVE // nghỉ việc / dừng hợp tác
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum TeacherRole {
  TEACHER
  ASSISTANT
  BOTH
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  OPEN
  CLOSED
  DELETED
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  DROPPED
  COMPLETED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum InvoiceStatus {
  UNPAID // chưa trả
  PARTIAL // trả 1 phần
  PAID // đủ
  OVERPAID // trả dư
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
}

enum RecipientType {
  PARENT
  STUDENT
  STAFF
}

enum NotificationType {
  ABSENCE
  TUITION
  GENERAL
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DiscountType {
  PERCENT
  AMOUNT
}

enum PromotionStatus {
  ACTIVE // đang chạy
  INACTIVE // bị tắt thủ công
  SCHEDULED // chưa tới ngày start
  EXPIRED // hết hạn
}

enum ActivityType {
  CREATE
  UPDATE
  DELETE
  ACTION
}

// ================================== MODEL ==================================
model User {
  id String @id @default(uuid())

  email String @unique

  password String

  fullName String

  phone String?

  address String?

  avatarUrl String?

  dateOfBirth DateTime?

  gender Gender?

  lastLoginAt DateTime?

  refreshToken String?

  role Role @default(STUDENT)

  status Status @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student?

  teacher Teacher?

  parent Parent?

  recordedAttendances Attendance[]
  createdResults      LearningResult[]
  payments            Payment[]
  leaveReviews        LeaveRequest[]
  activityLogs        ActivityLog[]

  @@map("users")
}

model Student {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Parent? @relation(fields: [parentId], references: [id])

  studentCode String @unique

  gradeLevel String?

  schoolName String?

  latestTestScore Decimal @default(0) @db.Decimal(5, 2)

  entryAcademicLevel String?

  learningGoal String?

  note String?

  status StudentStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances     Attendance[]
  learningResults LearningResult[]
  invoices        TuitionInvoice[]
  leaveRequests   LeaveRequest[]
  enrollments     Enrollment[]
  Notification    Notification[]

  @@map("students")
}

model Teacher {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  teacherCode String @unique

  teacherRole TeacherRole @default(TEACHER)

  specialization String?

  qualification String?

  yearsOfExperience Int?

  note String?

  status TeacherStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mainClasses      CourseClass[] @relation("MainTeacher")
  assistantClasses CourseClass[] @relation("AssistantTeacher")

  @@map("teachers")
}

model Parent {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students Student[]

  @@map("parents")
}

model Course {
  id String @id @default(uuid())

  courseCode String @unique

  name String

  description String?

  thumbnailUrl String?

  level CourseLevel?

  totalSessions Int @default(24)

  status CourseStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseClasses CourseClass[]

  @@map("courses")
}

model Room {
  id String @id @default(uuid())

  roomCode String @unique

  name String

  capacity Int

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseClasses CourseClass[]

  @@map("rooms")
}

model ScheduleSlot {
  id String @id @default(uuid())

  slotCode String @unique

  // 2 = Mon ... 8 = Sun
  weekday Int

  startTime String
  endTime   String

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseClasses CourseClass[]

  @@map("schedule_slots")
}

model CourseClass {
  id String @id @default(uuid())

  classCode String @unique

  name String

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  roomId String
  room   Room   @relation(fields: [roomId], references: [id])

  scheduleSlotId String
  scheduleSlot   ScheduleSlot @relation(fields: [scheduleSlotId], references: [id])

  mainTeacherId String
  mainTeacher   Teacher @relation("MainTeacher", fields: [mainTeacherId], references: [id])

  assistantTeacherId String?
  assistantTeacher   Teacher? @relation("AssistantTeacher", fields: [assistantTeacherId], references: [id])

  startDate DateTime

  endDate DateTime

  maxStudents Int?

  tuitionFee Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments     Enrollment[]
  attendances     Attendance[]
  learningResults LearningResult[]
  invoices        TuitionInvoice[]
  leaveRequests   LeaveRequest[]

  @@map("course_classes")
}

model Enrollment {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  courseClassId String
  courseClass   CourseClass @relation(fields: [courseClassId], references: [id], onDelete: Cascade)

  status EnrollmentStatus @default(ACTIVE)

  enrolledAt DateTime @default(now())

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, courseClassId])
  @@map("enrollments")
}

model Attendance {
  id String @id @default(uuid())

  courseClassId String
  courseClass   CourseClass @relation(fields: [courseClassId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  attendanceDate DateTime

  status AttendanceStatus

  note String?

  recordedByUserId String?
  recordedByUser   User?   @relation(fields: [recordedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseClassId, studentId, attendanceDate])
  @@map("attendances")
}

model LearningResult {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  courseClassId String
  courseClass   CourseClass @relation(fields: [courseClassId], references: [id], onDelete: Cascade)

  /// Use first day of month (e.g. 2026-09-01)
  resultMonth DateTime

  score Decimal? @db.Decimal(5, 2)

  teacherComment String?

  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, courseClassId, resultMonth])
  @@map("learning_results")
}

model Promotion {
  id String @id @default(uuid())

  promoCode String @unique

  name String

  discountType DiscountType

  discountValue Decimal @db.Decimal(12, 2)

  startDate DateTime
  endDate   DateTime

  status PromotionStatus @default(SCHEDULED)

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices TuitionInvoice[]

  @@map("promotions")
}

model TuitionInvoice {
  id String @id @default(uuid())

  invoiceCode String @unique

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  courseClassId String
  courseClass   CourseClass @relation(fields: [courseClassId], references: [id], onDelete: Cascade)

  /// Use first day of month (e.g. 2026-09-01)
  billingMonth DateTime

  originalAmount Decimal @db.Decimal(12, 2)

  discountAmount Decimal @default(0) @db.Decimal(12, 2)

  finalAmount Decimal @db.Decimal(12, 2)

  amountPaid Decimal @default(0) @db.Decimal(12, 2)

  balanceAmount Decimal @default(0) @db.Decimal(12, 2)

  status InvoiceStatus @default(UNPAID)

  promotionId String?
  promotion   Promotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull)

  dueDate DateTime?

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]

  @@unique([studentId, courseClassId, billingMonth])
  @@map("tuition_invoices")
}

model Payment {
  id String @id @default(uuid())

  invoiceId String
  invoice   TuitionInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  paymentCode String @unique

  paidAmount Decimal @db.Decimal(12, 2)

  paymentMethod PaymentMethod

  paidAt DateTime

  cashierUserId String?
  cashierUser   User?   @relation(fields: [cashierUserId], references: [id], onDelete: SetNull)

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model Notification {
  id String @id @default(uuid())

  recipientType RecipientType

  /// ID của người nhận (studentId / userId / parentId tuỳ hệ thống mapping runtime)
  recipientRefId String

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  type NotificationType

  title String @db.VarChar(150)

  content String @db.VarChar(500)

  relatedEntityType String?
  relatedEntityId   String?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("notifications")
}

model LeaveRequest {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  courseClassId String
  courseClass   CourseClass @relation(fields: [courseClassId], references: [id], onDelete: Cascade)

  leaveDate DateTime

  reason String @db.VarChar(500)

  status LeaveRequestStatus @default(PENDING)

  reviewerId String?
  reviewer   User?   @relation(fields: [reviewerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, courseClassId, leaveDate])
  @@map("leave_requests")
}

model ActivityLog {
  id String @id @default(uuid())

  type ActivityType

  // ai thực hiện action
  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  // entity bị tác động
  entityType String // "student", "invoice", "payment", "course_class"
  entityId   String

  title       String
  description String?

  metadata Json? // optional: store extra context

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}
